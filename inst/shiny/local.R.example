# Copy to local.R (gitignored) for local development or server overrides.
# save_local_shiny() never overwrites an existing local.R.

# --- Display-only vs Live Run ---
# save_local_shiny(dest, live_run = FALSE) writes deploy-options.R (display-only prod).
# For local dev, override here (only when not using deploy-options from save_local_shiny):
# options(replicate_shiny.live_run = TRUE)

# --- Monorepo development (sibling registry/ and rep-* study folders) ---
# Option A: paths relative to the shiny app directory (monorepo layout)
registry_root <- normalizePath("../registry", winslash = "/", mustWork = FALSE)
package_root <- normalizePath("../replicateEverything", winslash = "/", mustWork = FALSE)
packages_root <- normalizePath("..", winslash = "/", mustWork = FALSE)

# --- Monorepo development (sibling registry/ and rep-* study folders) ---
# Option A: paths relative to the shiny app directory (monorepo layout)
registry_root <- normalizePath("../registry", winslash = "/", mustWork = FALSE)
package_root <- normalizePath("../replicateEverything", winslash = "/", mustWork = FALSE)
packages_root <- normalizePath("..", winslash = "/", mustWork = FALSE)

# Option B: absolute monorepo root when running from an installed library copy.
# run_shiny_app() sets this automatically when launched from replicateEverything/.
# Sys.setenv(REPLICATE_MONOREPO_ROOT = "c:/path/to/replicate_everything")

# Study data on Shiny Server (relative to getwd() or study_data_root):
#   data/<study_folder>/<file>
# <study_folder> must match replication.yml paper.study_folder, e.g.
#   data/rep-10.1596-1813-9450-10626/ACS2017-2021_finalready.dta
# Local dev: large files usually stay in the sibling rep-* repo under data/
# (not git-synced). run_shiny_app() from the monorepo wires that up.
# Override working directory if needed:
# options(replicateEverything.study_data_root = "/wzb/samba/user/ipi/replicate")

# Share links always point at the public server (never localhost). If shiny2 moves, set:
# Sys.setenv(REPLICATE_SHINY_BASE_URL = "https://shiny2.wzb.eu/ipi/replicate")
# (Default is LIVE_DEMO_URL at the top of app.R.)
#
# Optional: show study root on the Code tab while debugging path resolution:
# options(replicate_shiny.debug_code_viewer = TRUE)
#
# Optional: server-side feedback log (Shiny Feedback tab writes JSON lines here):
# Sys.setenv(REPLICATE_SHINY_FEEDBACK_DIR = "/var/log/replicate-shiny/feedback")
# options(replicate_shiny.feedback_dir = "/var/log/replicate-shiny/feedback")

if (dir.exists(registry_root) && file.exists(file.path(registry_root, "index.csv"))) {
  options(
    replicateEverything.registry_root = registry_root,
    replicateEverything.index = utils::read.csv(
      file.path(registry_root, "index.csv"),
      stringsAsFactors = FALSE
    )
  )
}

options(
  replicate_shiny.auto_update_replicate_everything = FALSE,
  replicate_shiny.auto_install_study_packages = FALSE
)

if (!is.null(packages_root) && dir.exists(packages_root)) {
  options(
    replicateEverything.replication_packages_root = packages_root,
    replicateEverything.study_folders_root = packages_root,
    replicateEverything.use_sibling_packages = TRUE
  )
}

if (dir.exists(package_root) && requireNamespace("devtools", quietly = TRUE)) {
  devtools::load_all(package_root, quiet = TRUE)
  options(replicate_shiny.use_local_replicate_everything = TRUE)
  if (exists("load_sibling_replication_packages", envir = asNamespace("replicateEverything"), inherits = FALSE)) {
    get("load_sibling_replication_packages", envir = asNamespace("replicateEverything"))(packages_root)
  }
}

message("local.R loaded")
